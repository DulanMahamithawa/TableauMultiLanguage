<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.poc.multilang-translator" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name">AI Multi-Language Translator</name>
    <description>LLM-powered dashboard translation for English, French, and Swedish</description>
    <author name="POC Team" email="poc@company.com" organization="Company" website="https://localhost"/>
    <min-api-version>1.10</min-api-version>
    <source-location>
      <url>REPLACE_WITH_YOUR_HOSTED_URL/index.html</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAACXBIWXMAAAsTAAALEwEAmpwYAAAAGXRFWHRTb2Z0d2FyZQBBZG9iZSBJbWFnZVJlYWR5ccllPAAAAGlJREFUeNpi/P//PwMlgImBQsACY1AKBgYGBiYGCgEDAwMDEwOFgIGBgYGJgUIAAAAA//8DABl2BAABZAAJAAAAAElFTkSuQmCC</icon>
  </dashboard-extension>
</manifest>
